{
    "name": "farm-manager",
    "version": "1.0.0",
    "description": "Farm Manager - Smart Agricultural Management System",
    "scripts": {
        "install:all": "npm install && cd server && npm install && cd ../client && npm install",
        "server": "cd server && npm run dev",
        "client": "cd client && npm start",
        "dev": "concurrently \"npm run server\" \"npm run client\"",
        "build": "cd client && npm run build"
    },
    "keywords": [
        "farm",
        "agriculture",
        "water-management",
        "ai",
        "sheep"
    ],
    "author": "Adan Farmer",
    "license": "MIT",
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}